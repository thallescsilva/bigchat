# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/bigchat
DATABASE_USER=bigchat
DATABASE_PASSWORD=bigchat

# Auth
JWT_SECRET=change-this-secret-in-production-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# CORS (origens permitidas, separadas por vírgula)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# AI (opcional — sem a key o app usa fallback de sugestões)
ANTHROPIC_API_KEY=
ANTHROPIC_TIMEOUT_SECONDS=10

# Frontend (vazio = mesma origem; nginx faz proxy no container)
VITE_API_URL=
